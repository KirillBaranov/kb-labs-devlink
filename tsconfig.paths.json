{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@kb-labs/devlink-contracts": [
        "packages/devlink-contracts/src/index.ts"
      ],
      "@kb-labs/devlink-contracts/*": [
        "packages/devlink-contracts/src/*"
      ],
      "@kb-labs/devlink-core": [
        "packages/devlink-core/src/index.ts"
      ],
      "@kb-labs/devlink-core/*": [
        "packages/devlink-core/src/*"
      ],
      "@kb-labs/sdk": [
        "../kb-labs-sdk/packages/sdk/src/index.ts"
      ],
      "@kb-labs/sdk/*": [
        "../kb-labs-sdk/packages/sdk/src/*"
      ]
    }
  }
}
